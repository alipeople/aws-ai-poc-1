# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:50001

# ── Backend (AWS) ───────────────────────────────────────────
# 방법 1: AWS 프로파일 사용 (추천 — ~/.aws/credentials 프로파일명)
AWS_PROFILE=your-profile-name
# 방법 2: 직접 키 입력 (AWS_PROFILE 미설정 시 사용)
# AWS_ACCESS_KEY_ID=your-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-here
AWS_REGION=ap-northeast-2
# 사용 가능: global.anthropic.claude-opus-4-6-v1, apac.anthropic.claude-sonnet-4-20250514-v1:0
DEFAULT_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# ── Backend (App) ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:50000"]
